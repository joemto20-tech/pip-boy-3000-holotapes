{
  "id": "iPip",
  "name": "iPip Media Player",
  "author": "@CodyTolene",
  "version": "2.0.0",
  "description": "iPip is a full media player for the Pip-Boy 3000. Play WAV playlists from `MUSIC/`, watch AVI clips from `VIDEOS/`, and view images from `IMAGES/`, all from one Vault-Tec approved holotape.",
  "icon": "assets/IPIP.PNG",
  "previews": [],
  "type": "app",
  "readme": "README.md",
  "storage": [
    { "name": "HOLO/IPIP/APP.JS", "url": "APP.MIN.JS" },
    { "name": "HOLO/IPIP/IMAGES.JS", "url": "assets/IMAGES.MIN.JS" },
    { "name": "HOLO/IPIP/IMG_IPIP.BIN", "url": "assets/IMG_IPIP.BIN" },
    { "name": "HOLO/IPIP/INTRO.JS", "url": "assets/INTRO.MIN.JS" },
    { "name": "HOLO/IPIP/MENU.JS", "url": "assets/MENU.MIN.JS" },
    { "name": "HOLO/IPIP/MUSIC.JS", "url": "assets/MUSIC.MIN.JS" },
    { "name": "HOLO/IPIP/SETTINGS.JS", "url": "assets/SETTINGS.MIN.JS" },
    { "name": "HOLO/IPIP/SND_INTRO.WAV", "url": "assets/SND_INTRO.WAV" },
    { "name": "HOLO/IPIP/VIDEO.JS", "url": "assets/VIDEO.MIN.JS" }
  ],
  "storageOptional": [
    {
      "label": "Example JS Image",
      "name": "IMAGES/IMG_IPIP_EXAMPLE.JS",
      "sizeKB": 12,
      "url": "assets/examples/IMG_IPIP_EXAMPLE.JS"
    },
    {
      "label": "Example JSON Image",
      "name": "IMAGES/IMG_IPIP_EXAMPLE.JSON",
      "sizeKB": 9,
      "url": "assets/examples/IMG_IPIP_EXAMPLE.JSON"
    },
    {
      "label": "Example BIN Image",
      "name": "IMAGES/IMG_IPIP_EXAMPLE_FULL_SCREEN.BIN",
      "sizeKB": 38,
      "url": "assets/examples/IMG_IPIP_EXAMPLE_FULL_SCREEN.BIN"
    },
    {
      "label": "Example AVI Video",
      "name": "VIDEOS/S.P.E.C.I.A.L..AVI",
      "sizeKB": 616,
      "url": "assets/examples/S.P.E.C.I.A.L..AVI"
    }
  ]
}
